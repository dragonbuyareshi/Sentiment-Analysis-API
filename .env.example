# ── Sentiment Analysis API — Environment Variables ──────────────
# Copy to .env and adjust values before running

# Model paths
MODEL_DIR=models/checkpoints/final
ONNX_PATH=models/checkpoints/model_sim.onnx
USE_ONNX=true
MAX_LENGTH=128

# API Security — change these in production!
API_KEYS=dev-key-123,your-production-key-here

# Redis
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# Server
PORT=8000
LOG_LEVEL=INFO
